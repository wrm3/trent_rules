{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/session-start.ps1"
      }
    ],
    "stop": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/agent-complete.ps1"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/validate-shell.ps1"
      }
    ]
  }
}
