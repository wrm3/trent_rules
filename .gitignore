# ============================================================================
# KEEP THESE - Template Content (for distribution)
# ============================================================================
# Task management system - NOW INCLUDED IN REPO
!.fstrent_spec_tasks/
!.fstrent_spec_tasks/**/*

# Cursor configuration
!.cursor/
!.cursor/**/*

# Cursor logs and metrics (session-specific, not for distribution)
# These rules come AFTER !.cursor/**/* to override that unignore
.cursor/logs/*
!.cursor/logs/.gitkeep
template/.cursor/logs/*
!template/.cursor/logs/.gitkeep
.cursor/metrics/*
!.cursor/metrics/.gitkeep
# Claude metrics (session-specific, not for distribution)
.claude/metrics/*
!.claude/metrics/.gitkeep
template_v2/.claude/metrics/*
!template_v2/.claude/metrics/.gitkeep
template_old/.claude/metrics/*
!template_old/.claude/metrics/.gitkeep

# Other IDE configurations
!.windsurf/
!.windsurf/**/*
!.roo-code/
!.roo-code/**/*
!.cline/
!.cline/**/*

# Template folder (everything to copy to new projects)
!template/
!template/**/*

# Example project
!example-project/
!example-project/**/*

# Documentation (private - not for distribution)
docs/

# Platform docs subdirectories (these MUST be tracked — crawled reference content)
!.platforms/**

# GitHub files
!.github/
!.github/**/*

# Root files
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md
!.gitignore
!.mcp.json
!agents.md

# Docker has no separate .env.example - use repo root .env.example
docker/.env.example
