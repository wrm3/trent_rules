# AI Project Template - .gitignore
# For public repository - blocks research, personal data, and sensitive files

# ============================================================================
# Migration working directories (completed — production is in .cursor/.claude/.agent)
# ============================================================================
.hybrid/
.hybrid/claude/
.hybrid/cursor/
.hybrid/cursor_original/

# Rule backup snapshots (created during migrations, local only)
.cursor/rules_backup_*/
.claude/rules_backup_*/
.agent/rules_backup_*/

.trent/logs/

.trent_bk_2026_03_08.zip
.trent_bk_2026_03_09.zip

# Superseded tools (evolved into docker/trent/admin_db_rest.py)
portable-db-explorer/

# ============================================================================
# Temporary Notes & Working Documents (local only, never committed)
# ============================================================================
temp_docs/

# ============================================================================
# Research & Development (Private - development artifacts)
# ============================================================================
research/
research_future_dev/

# ============================================================================
