# ============================================================================
*_api_key*
*_token*
*_secret*
.anthropic_api_key
.openai_api_key

# ============================================================================
# Personal Data & Logs
# ============================================================================
# Block ALL log files everywhere, including nested directories (.hybrid/, etc.)
*.log
logs/
**/logs/
**/logs/*
!**/logs/.gitkeep
# Block metrics CSVs (contain session data, not for distribution)
**/*.csv
!**/.gitkeep
*.sqlite
*.db
*.db-journal
personal/
private/

