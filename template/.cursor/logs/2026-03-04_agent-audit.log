[2026-03-04T05:01:07Z] [unknown] n++{"conversation_id":"2a12bd8d-f3eb-4225-a92c-586e34e15094","generation_id":"fa0ef714-7f2c-4528-983f-8ce9ef5386b3","model":"claude-4.6-sonnet-medium-thinking","tool_name":"Write","tool_input":{"file_path":"G:\\trent_rules\\temp_scripts\\test_memory_fallback.py","content":"\"\"\"\ntest_memory_fallback.py GÇö Test 5: Fallback mechanism when server is offline.\n\nUsage:\n    python temp_scripts/test_memory_fallback.py --project-path G:\\\\my_project\n\nSteps:\n    1. Directly invokes the fallback write function (simulates server-down)\n    2. Verifies .trent/memory_fallback.jsonl is created\n    3. Verifies file content is valid JSONL\n    4. Provides instructions for testing drain via session-start.ps1\n\"\"\"\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).parent.parent / \".cursor\" / \"hooks\"))\n\n\ndef test_5_fallback_write(project_path: str) -> bool:\n    \"\"\"Test 5: Fallback mechanism GÇö simulate server down.\"\"\"\n    print(\"\\n=== Test 5: Fallback Write Mechanism ===\")\n\n    from claude_adapter import _write_fallback  # type: ignore\n\n    project_path_obj = Path(project_path)\n    fallback_path = project_path_obj / \".trent\" / \"memory_fallback.jsonl\"\n\n    # Remove existing fallback for clean test\n    if fallback_path.exists():\n        fallback_path.unlink()\n        print(f\"  Removed existing fallback: {fallback_path}\")\n\n    test_project_id = \"test-proj-fallback-001\"\n    test_session_id = \"test-session-fallback-001\"\n    test_turns = [\n        {\"user\": \"Test user message\", \"agent\": \"Test agent response\"},\n        {\"user\": \"Second message\", \"agent\": \"Second response\"},\n    ]\n\n    # Call fallback write (simulates what happens when server is down)\n    _write_fallback(\n        project_path=project_path_obj,\n        project_id=test_project_id,\n        session_id=test_session_id,\n        turns=test_turns,\n        status=\"completed\",\n        error=\"Connection refused GÇö server offline (test)\",\n    )\n\n    # Verify file was created\n    if not fallback_path.exists():\n        print(f\"  FAIL: Fallback file not created at {fallback_path}\")\n        return False\n    print(f\"  PASS: Fallback file created at {fallback_path}\")\n\n    # Verify content is valid JSONL\n    lines = fallback_path.read_text(encoding=\"utf-8\").strip().splitlines()\n    if not lines:\n        print(\"  FAIL: Fallback file is empty\")\n        return False\n\n    record = json.loads(lines[-1])\n    assert record[\"project_id\"] == test_project_id, f\"project_id mismatch: {record['project_id']}\"\n    assert record[\"conversation_id\"] == test_session_id, f\"conversation_id mismatch\"\n    assert len(record[\"turns\"]) == len(test_turns), f\"turns count mismatch\"\n    assert \"fallback_timestamp\" in record, \"Missing fallback_timestamp\"\n    assert \"error\" in record, \"Missing error field\"\n    print(f\"  PASS: Valid JSONL record GÇö project_id={record['project_id']} turns={len(record['turns'])}\")\n\n    # Test append mode GÇö write a second record\n    _write_fallback(\n        project_path=project_path_obj,\n        project_id=test_project_id,\n        session_id=\"test-session-fallback-002\",\n        turns=[{\"user\": \"Another session\", \"agent\": \"Another response\"}],\n        status=\"partial\",\n        error=\"Timeout (test)\",\n    )\n\n    lines = fallback_path.read_text(encoding=\"utf-8\").strip().splitlines()\n    if len(lines) != 2:\n        print(f\"  FAIL: Expected 2 records after append, got {len(lines)}\")\n        return False\n    print(f\"  PASS: Append mode works GÇö {len(lines)} records in fallback file\")\n\n    print(f\"\\n  Fallback file preview:\")\n    for i, line in enumerate(lines):\n        rec = json.loads(line)\n        print(f\"    Record {i+1}: conv={rec['conversation_id']} turns={len(rec['turns'])} error={rec['error'][:50]}\")\n\n    print(f\"\"\"\n  To test the drain:\n    1. Ensure trent server is running (docker-compose up -d)\n    2. Run: powershell -ExecutionPolicy Bypass -File .cursor/hooks/session-start.ps1\n    3. Verify fallback file is removed/emptied after drain\n  \"\"\")\n\n    return True\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Test memory fallback mechanism\")\n    parser.add_argument(\"--project-path\", default=\".\", help=\"Path to project root (default: cwd)\")\n    args = parser.parse_args()\n\n    results = [test_5_fallback_write(args.project_path)]\n\n    passed = sum(1 for r in results if r)\n    print(f\"\\n{'='*40}\")\n    print(f\"RESULTS: {passed}/{len(results)} passed\")\n    sys.exit(0 if passed == len(results) else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"},"tool_use_id":"toolu_bdrk_01RWdPMBksfU74DTasJox7Si","hook_event_name":"preToolUse","cursor_version":"2.5.26","workspace_roots":["/g:/trent_rules"],"user_email":"fstrent@gmail.com","transcript_path":"c:\\Users\\FSTrent\\.cursor\\projects\\g-trent-rules\\agent-transcripts\\2a12bd8d-f3eb-4225-a92c-586e34e15094\\2a12bd8d-f3eb-4225-a92c-586e34e15094.jsonl"}

