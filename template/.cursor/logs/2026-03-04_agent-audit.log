[2026-03-04T05:00:20Z] [unknown] n++{"conversation_id":"2a12bd8d-f3eb-4225-a92c-586e34e15094","generation_id":"fa0ef714-7f2c-4528-983f-8ce9ef5386b3","model":"claude-4.6-sonnet-medium-thinking","tool_name":"Write","tool_input":{"file_path":"G:\\trent_rules\\temp_scripts\\test_memory_ingest.py","content":"\"\"\"\ntest_memory_ingest.py GÇö Tests 1-2: Adapter GåÆ REST Endpoint and memory_capture_session MCP tool.\n\nUsage:\n    python temp_scripts/test_memory_ingest.py --project-id <proj_id> [--mcp-url http://localhost:8082]\n\nRequires:\n    - trent MCP server running (docker-compose up -d)\n    - OPENAI_API_KEY set in environment (for embeddings)\n\"\"\"\n\nimport argparse\nimport json\nimport sys\nimport urllib.request\nimport urllib.error\nfrom datetime import datetime, timezone\n\nDEFAULT_MCP_URL = \"http://localhost:8082\"\nTEST_SESSION_ID = \"test-memory-ingest-001\"\n\n\ndef post_json(url: str, payload: dict, timeout: int = 30) -> dict:\n    data = json.dumps(payload).encode(\"utf-8\")\n    req = urllib.request.Request(url, data=data, headers={\"Content-Type\": \"application/json\"}, method=\"POST\")\n    try:\n        with urllib.request.urlopen(req, timeout=timeout) as resp:\n            return json.loads(resp.read().decode(\"utf-8\"))\n    except urllib.error.HTTPError as e:\n        body = e.read().decode(\"utf-8\", errors=\"replace\")\n        print(f\"  HTTP {e.code}: {body[:400]}\")\n        return {\"success\": False, \"error\": f\"HTTP {e.code}: {body[:200]}\"}\n    except Exception as e:\n        return {\"success\": False, \"error\": str(e)}\n\n\ndef test_health(mcp_url: str) -> bool:\n    print(\"\\n=== Health Check ===\")\n    try:\n        with urllib.request.urlopen(f\"{mcp_url}/memory/health\", timeout=5) as resp:\n            body = json.loads(resp.read().decode(\"utf-8\"))\n            print(f\"  db_connected: {body.get('db_connected')}\")\n            print(f\"  endpoints: {body.get('endpoints')}\")\n            return body.get(\"success\", False)\n    except Exception as e:\n        print(f\"  FAILED: {e}\")\n        return False\n\n\ndef test_1_ingest_turns(project_id: str, mcp_url: str) -> bool:\n    \"\"\"Test 1: POST raw turns to /memory/ingest REST endpoint.\"\"\"\n    print(\"\\n=== Test 1: POST /memory/ingest (Tier-1 passive) ===\")\n    ts = datetime.now(timezone.utc).isoformat()\n    payload = {\n        \"project_id\": project_id,\n        \"conversation_id\": TEST_SESSION_ID,\n        \"platform\": \"claude_code\",\n        \"status\": \"completed\",\n        \"turns\": [\n            {\n                \"user\": \"How do I set up the database schema for the memory system?\",\n                \"agent\": \"You need to create agent_projects, agent_sessions, agent_turns, and agent_memory_captures tables with pgvector embeddings.\",\n                \"tool_names\": [\"read_file\", \"write_file\"],\n                \"file_refs\": [\"docker/trent/database/schema.sql\"],\n            },\n            {\n                \"user\": \"What is the fallback mechanism?\",\n                \"agent\": \"When the server is unavailable, adapters write to .trent/memory_fallback.jsonl which is drained on next session start.\",\n                \"tool_names\": [],\n                \"file_refs\": [\".cursor/hooks/claude_adapter.py\"],\n            },\n        ],\n    }\n\n    result = post_json(f\"{mcp_url}/memory/ingest\", payload)\n    if result.get(\"success\"):\n        print(f\"  PASS: ingested_turns={result.get('ingested_turns')} session_db_id={result.get('session_db_id')}\")\n        return True\n    else:\n        print(f\"  FAIL: {result.get('error')}\")\n        return False\n\n\ndef test_2_capture_session(project_id: str, mcp_url: str) -> bool:\n    \"\"\"Test 2: POST session summary to /memory/capture (Tier-2 active).\"\"\"\n    print(\"\\n=== Test 2: POST /memory/capture (Tier-2 active) ===\")\n    payload = {\n        \"project_id\": project_id,\n        \"conversation_id\": f\"test-capture-{TEST_SESSION_ID}\",\n        \"platform\": \"claude_code\",\n        \"summary\": \"Set up the memory system tests. Created test scripts for ingest, search, fallback, and end-to-end pipeline validation.\",\n        \"key_decisions\": \"Used JSONL format for fallback file GÇö human-readable and append-safe\",\n        \"files_changed\": \"temp_scripts/test_memory_ingest.py, temp_scripts/test_memory_search.py\",\n    }\n\n    result = post_json(f\"{mcp_url}/memory/capture\", payload)\n    if result.get(\"success\"):\n        print(f\"  PASS: capture_id={result.get('capture_id')} session_db_id={result.get('session_db_id')}\")\n        return True\n    else:\n        print(f\"  FAIL: {result.get('error')}\")\n        return False\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Test memory ingest and capture endpoints\")\n    parser.add_argument(\"--project-id\", required=True, help=\"trent project ID (.trent/.project_id)\")\n    parser.add_argument(\"--mcp-url\", default=DEFAULT_MCP_URL)\n    args = parser.parse_args()\n\n    mcp_url = args.mcp_url.rstrip(\"/\")\n\n    if not test_health(mcp_url):\n        print(\"\\nServer not healthy GÇö aborting tests\")\n        sys.exit(1)\n\n    results = []\n    results.append(test_1_ingest_turns(args.project_id, mcp_url))\n    results.append(test_2_capture_session(args.project_id, mcp_url))\n\n    passed = sum(1 for r in results if r)\n    print(f\"\\n{'='*40}\")\n    print(f\"RESULTS: {passed}/{len(results)} passed\")\n    sys.exit(0 if passed == len(results) else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"},"tool_use_id":"toolu_bdrk_01R9LeMNnVBcPW4wpNC9sRNP","hook_event_name":"preToolUse","cursor_version":"2.5.26","workspace_roots":["/g:/trent_rules"],"user_email":"fstrent@gmail.com","transcript_path":"c:\\Users\\FSTrent\\.cursor\\projects\\g-trent-rules\\agent-transcripts\\2a12bd8d-f3eb-4225-a92c-586e34e15094\\2a12bd8d-f3eb-4225-a92c-586e34e15094.jsonl"}

