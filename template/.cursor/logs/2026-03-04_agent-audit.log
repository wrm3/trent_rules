    lines.append(f\"Files: {cap['files_changed']}\")\n\n    context_text = \"\\n\".join(lines)\n    if len(context_text) > approx_chars:\n        context_text = (\n            context_text[:approx_chars]\n            + \"\\n\\n[...memory truncated to fit token budget]\"\n        )\n\n    return {\n        \"success\": True,\n        \"project_id\": project_id,\n        \"context\": context_text,\n        \"approx_tokens\": len(context_text) // 4,\n        \"sessions_included\": len(sessions),\n    }\n"},"tool_output":"{\"file_path\":\"G:\\\\trent_rules\\\\docker\\\\trent\\\\tools\\\\plugins\\\\memory_context.py\",\"success\":true}","duration":53.269,"tool_use_id":"toolu_bdrk_012ip7tWkB1erTsoCQ6CumEA","hook_event_name":"postToolUse","cursor_version":"2.5.26","workspace_roots":["/g:/trent_rules"],"user_email":"fstrent@gmail.com","transcript_path":"c:\\Users\\FSTrent\\.cursor\\projects\\g-trent-rules\\agent-transcripts\\2a12bd8d-f3eb-4225-a92c-586e34e15094\\2a12bd8d-f3eb-4225-a92c-586e34e15094.jsonl"}

[2026-03-04T04:57:05Z] [unknown] n++{"conversation_id":"2a12bd8d-f3eb-4225-a92c-586e34e15094","generation_id":"fa0ef714-7f2c-4528-983f-8ce9ef5386b3","model":"claude-4.6-sonnet-medium-thinking","tool_name":"Write","tool_input":{"file_path":"G:\\trent_rules\\docker\\trent\\tools\\plugins\\_agent_memory_shared.py","content":"\"\"\"\nShared helpers for agent_memory MCP tools.\nUnderscore prefix = utility module (not auto-loaded as a plugin).\n\nInjected context keys:\n  db                 GÇö RAGDatabase instance\n  embedding_generator GÇö EmbeddingGenerator instance\n\"\"\"\n\nfrom __future__ import annotations\n\nimport hashlib\nimport json\nimport logging\nimport os\nfrom datetime import datetime, timezone\nfrom typing import Any, Optional\n\nlogger = logging.getLogger(__name__)\n\nMAX_CONTEXT_TOKENS = 4000\nOPENAI_MODEL_SUMMARY = \"gpt-4o-mini\"\n\n# GöÇGöÇ Shared state injected by each plugin's setup() GöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇ\n_db = None\n_embedding_gen = None\n\n\ndef init(context: dict) -> None:\n    \"\"\"Call from each plugin's setup() to wire in shared state.\"\"\"\n    global _db, _embedding_gen\n    _db = context.get(\"db\")\n    _embedding_gen = context.get(\"embedding_generator\")\n\n\n# GöÇGöÇ Database helpers GöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇGöÇ\n\ndef upsert_project(project_id: str, user_id: str, machine_id: str,\n                   project_path: str, display_name: str) -> int:\n    with _db.get_cursor() as cur:\n        cur.execute(\n            \"SELECT upsert_agent_project(%s, %s, %s, %s, %s)\",\n            (project_id, user_id, machine_id, project_path, display_name),\n        )\n        row = cur.fetchone()\n        # RealDictCursor returns a dict; the function result is keyed by the function name\n        return list(row.values())[0]\n\n\ndef ensure_session(conversation_id: str, project_row_id: int,\n                   platform: str, capture_tier: str,\n                   status: Optional[str], loop_count: Optional[int]) -> int:\n    with _db.get_cursor() as cur:\n        cur.execute(\n            \"\"\"\n            INSERT INTO agent_sessions\n                (conversation_id, project_id, platform, capture_tier,\n                 status, loop_count, ended_at)\n            VALUES (%s, %s, %s, %s, %s, %s, NOW())\n            ON CONFLICT (conversation_id) DO UPDATE\n                SET status     = EXCLUDED.status,\n                    loop_count = EXCLUDED.loop_count\n            RETURNING id\n            \"\"\",\n            (conversation_id, project_row_id, platform, capture_tier,\n             status, loop_count),\n        )\n        return cur.fetchone()[\"id\"]\n\n\ndef content_hash(user_msg: str, agent_resp: str) -> str:\n    return hashlib.md5(f\"{user_msg}|||{agent_resp}\".encode()).hexdigest()\n\n\ndef summarise_turn(user_msg: str, agent_resp: str) -> tuple[str, str]:\n    \"\"\"GPT-4o-mini title + description; falls back to truncation.\"\"\"\n    try:\n        from openai import OpenAI\n        client = OpenAI(api_key=os.getenv(\"OPENAI_API_KEY\"))\n        prompt = (\n            \"Given this developer Gåö AI exchange, produce:\\n\"\n            \"1. A 10-15 word title (plain text)\\n\"\n            \"2. A 2-4 sentence description of what was accomplished\\n\\n\"\n            f\"User: {user_msg[:500]}\\n\\nAgent: {agent_resp[:1000]}\\n\\n\"\n            \"Respond as JSON: {\\\"title\\\": \\\"...\\\", \\\"description\\\": \\\"...\\\"}\"\n        )\n        resp = client.chat.completions.create(\n            model=OPENAI_MODEL_SUMMARY,\n            messages=[{\"role\": \"user\", \"content\": prompt}],\n            temperature=0.3,\n            max_tokens=200,\n        )\n        data = json.loads(resp.choices[0].message.content)\n        return data.get(\"title\", \"\")[:255], data.get(\"description\", \"\")\n    except Exception as e:\n        logger.warning(f\"summarise_turn LLM failed: {e}\")\n        title = (user_msg[:120] + \"...\") if len(user_msg) > 120 else user_msg\n        desc = (agent_resp[:400] + \"...\") if len(agent_resp) > 400 else agent_resp\n        return title, desc\n\n\ndef embed(text: str) -> Optional[list]:\n    if not _embedding_gen:\n        return None\n    try:\n        result = _embedding_gen.generate(text)\n        if hasattr(result, \"tolist\"):\n            return result.tolist()\n        return list(result)\n    except Exception as e:\n        logger.warning(f\"embed failed: {e}\")\n        return None\n\n\ndef embed_str(vec: Optional[list]) -> Optional[str]:\n    if not vec:\n        return None\n    return f\"[{','.join(map(str, vec))}]\"\n\n\ndef insert_turn(session_id: int, turn_index: int, user_msg: str,\n                agent_resp: str, platform: str, capture_tier: str) -> bool:\n    \"\"\"Returns True if inserted, False if duplicate.\"\"\"\n    chash = content_hash(user_msg, agent_resp)\n    with _db.get_cursor() as cur:\n        cur.execute(\n            \"SELECT 1 FROM agent_turns WHERE content_hash = %s\", (chash,)\n        )\n        if cur.fetchone():\n            return False\n\n    title, description = summarise_turn(user_msg, agent_resp)\n    emb = embed(f\"{title} {description}\")\n\n    with _db.get_cursor() as cur:\n        cur.execute(\n            \"\"\"\n            INSERT INTO agent_turns\n                (session_id, turn_index, content_hash, user_message,\n                 agent_response, llm_title, llm_description, embedding,\n                 platform, capture_tier)\n            VALUES (%s,%s,%s,%s,%s,%s,%s,%s::vector,%s,%s)\n            ON CONFLICT DO NOTHING\n            \"\"\",\n            (session_id, turn_index, chash, user_msg, agent_resp,\n             title, description, embed_str(emb), platform, capture_tier),\n        )\n    return True\n"},"tool_use_id":"toolu_bdrk_01FohtMpFoXpiQjRaUqQV7Vu","hook_event_name":"preToolUse","cursor_version":"2.5.26","workspace_roots":["/g:/trent_rules"],"user_email":"fstrent@gmail.com","transcript_path":"c:\\Users\\FSTrent\\.cursor\\projects\\g-trent-rules\\agent-transcripts\\2a12bd8d-f3eb-4225-a92c-586e34e15094\\2a12bd8d-f3eb-4225-a92c-586e34e15094.jsonl"}

