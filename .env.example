# ============================================================
# trent_rules_docker - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
#   copy .env.example .env
# Docker Compose reads this from the project root automatically.
# DO NOT commit .env to version control!
# ============================================================

# ============================================================
# PostgreSQL (Required for RAG)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=knowledge_base
POSTGRES_USER=knowledge_base
POSTGRES_PASSWORD=knowledge_base

# ============================================================
# Video Analyzer Configuration
# ============================================================
# Frame extraction settings
FRAME_INTERVAL=30
MAX_FRAMES=10
PLAYLIST_LIMIT=50

# Note: Video analyzer uses ANTHROPIC_API_KEY for vision analysis
# and OPENAI_API_KEY for embeddings (if RAG integration enabled)

# ============================================================
# Research APIs (Optional — used by research_deep / research_search tools)
# NO DuckDuckGo — uses Perplexity and Google instead
# ============================================================
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# ============================================================
# Anthropic (for research summaries and vision analysis)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ============================================================
# OpenAI (Required for embeddings)
# ============================================================
OPENAI_API_KEY=ADD_KEY_HERE

# ============================================================
# Gemini API (Upcoming — for Gemini/.agent platform support)
# Get a key at: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# Firecrawl (Platform Documentation Crawler)
# Optional — only needed if you run: docker compose --profile platform-docs up
# Get a key at: https://www.firecrawl.dev
# API endpoint used: https://api.firecrawl.dev/v1/crawl  (REST, NOT the CLI)
# Without this key the crawler falls back to basic single-page scraping only.
# ============================================================
FIRECRAWL_API_KEY=fc-your-key-here

# ============================================================
# MediaWiki (Optional — runs with: docker compose --profile mediawiki up)
# ============================================================
# --- Service URLs (change per environment: home, work, OKE) ---
# Home:       http://localhost:8880
# Work LAN:   http://192.168.x.x:8880
# OKE/K8s:    https://wiki.your-domain.com
MEDIAWIKI_SERVER=http://localhost:8880

# --- Wiki identity ---
MEDIAWIKI_SITE_NAME=Knowledge Base
MEDIAWIKI_PUBLIC=false

# --- Admin account (created on first install) ---
MEDIAWIKI_ADMIN_USER=WikiAdmin
MEDIAWIKI_ADMIN_PASSWORD=CHANGE_ME_strong_password
MEDIAWIKI_ADMIN_EMAIL=admin@localhost

# --- Database (uses shared Postgres instance — no MySQL needed) ---
MEDIAWIKI_DB_NAME=mediawiki
MEDIAWIKI_DB_PREFIX=mw_

# --- Security keys (REQUIRED — generate with: openssl rand -hex 32) ---
MEDIAWIKI_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
MEDIAWIKI_UPGRADE_KEY=GENERATE_WITH_openssl_rand_hex_16

# --- Bot credentials for mediawiki_page / mediawiki_search MCP tools ---
# Create a bot password in MediaWiki: Special:BotPasswords
# Format: WikiAdmin@BotName
MEDIAWIKI_USERNAME=WikiAdmin@trent_MCP
MEDIAWIKI_PASSWORD=CHANGE_ME_bot_password
MEDIAWIKI_API_KEY=

# ============================================================
# Server Configuration
# ============================================================
# Docker Compose OVERRIDES MCP_TRANSPORT, MCP_HOST, and MCP_PORT
# with container-specific values (streamable-http on 0.0.0.0:8082).
# The values below are only used if running the server outside Docker.
#
# Docker endpoints (what you actually connect to):
#   Main MCP:        http://localhost:8084/mcp
#   Video Analyzer:  http://localhost:8085/sse
# ============================================================
LOG_LEVEL=INFO
# These are defaults for non-Docker use only:
# MCP_TRANSPORT=stdio
# MCP_HOST=0.0.0.0
# MCP_PORT=8082

# ============================================================
# pgAdmin (Optional — database management UI)
# Start with: docker compose --profile admin up
# URL: http://localhost:8083
# Change per environment: home=localhost, work=192.168.x.x, OKE=pgadmin.domain.com
# ============================================================
PGADMIN_URL=http://localhost:8083
PGADMIN_EMAIL=admin@trent.local
PGADMIN_PASSWORD=CHANGE_ME_strong_password
