# ============================================================
# trent_rules_docker - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
#   copy .env.example .env
#
# Docker Compose reads this from the project root automatically.
# DO NOT commit .env to version control!
# ============================================================

# ============================================================
# PostgreSQL (Required for RAG)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=rag_knowledge
POSTGRES_USER=trent
POSTGRES_PASSWORD=rag_knowledge

# ============================================================
# OpenAI (Required for embeddings)
# ============================================================
OPENAI_API_KEY=ADD_KEY_HERE

# ============================================================
# Research APIs (Optional - at least one recommended)
# NO DuckDuckGo - uses Perplexity and Google instead
# ============================================================

# Perplexity API (best for research)
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here

# Google Custom Search (backup)
GOOGLE_SEARCH_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# Anthropic (for research summaries)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ============================================================
# MediaWiki (Optional - for mediawiki_* tools)
# ============================================================
MEDIAWIKI_URL=https://your-wiki.example.com
MEDIAWIKI_USERNAME=your_wiki_user
MEDIAWIKI_PASSWORD=your_wiki_password
MEDIAWIKI_API_KEY=your_bot_api_key

# ============================================================
# Server Configuration
# ============================================================
# Docker Compose OVERRIDES MCP_TRANSPORT, MCP_HOST, and MCP_PORT
# with container-specific values (streamable-http on 0.0.0.0:8082).
# The values below are only used if running the server outside Docker.
#
# Docker endpoints (what you actually connect to):
#   Main MCP:        http://localhost:8084/mcp
#   Video Analyzer:  http://localhost:8085/sse
# ============================================================
LOG_LEVEL=INFO
# These are defaults for non-Docker use only:
# MCP_TRANSPORT=stdio
# MCP_HOST=0.0.0.0
# MCP_PORT=8082

# ============================================================
# pgAdmin (Optional - for database management)
# Start with: docker compose --profile admin up
# ============================================================
PGADMIN_DEFAULT_EMAIL=admin@trent.local
PGADMIN_DEFAULT_PASSWORD=your-pgadmin-password-here

# ============================================================
# GitHub Configuration (for install_trent tool)
# ============================================================
# install_trent fetches templates directly from the GitHub repo
# using the GitHub Contents API. A read-only token is included
# by default for public access to the trent_rules repo.
#
# GITHUB_REPO   - Repository in "owner/repo" format
# GITHUB_TOKEN  - Personal access token with repo read access
#                 (A default read-only token is provided)
# ============================================================
GITHUB_REPO=wrm3/trent_rules
GITHUB_TOKEN=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

# ============================================================
# Firecrawl (Platform Documentation Crawler)
# Optional — only needed if you run: docker compose --profile platform-docs up
# Get a key at: https://www.firecrawl.dev
# API endpoint used: https://api.firecrawl.dev/v1/crawl  (REST, NOT the CLI)
# Without this key the crawler falls back to basic single-page scraping only.
# ============================================================
FIRECRAWL_API_KEY=fc-your-key-here

# ============================================================
# Video Analyzer Configuration
# ============================================================
# Frame extraction settings
FRAME_INTERVAL=30
MAX_FRAMES=10
PLAYLIST_LIMIT=50

# Note: Video analyzer uses ANTHROPIC_API_KEY for vision analysis
# and OPENAI_API_KEY for embeddings (if RAG integration enabled)
